# Legal AI Platform Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# APPLICATION SETTINGS
# ============================================
PROJECT_NAME="Legal AI Platform"
VERSION="1.0.0"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["*"]

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
SECRET_KEY="your-secret-key-here-change-in-production"
JWT_SECRET_KEY="your-jwt-secret-key-here-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL - Primary Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=legal_ai
DATABASE_URL="postgresql://postgres:password@localhost:5432/legal_ai"
TEST_DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/legal_ai_test"
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis - Caching & Sessions
REDIS_URL="redis://localhost:6379/0"

# Neo4j - Graph Database
# Pinned per docs/phase-1/1.5.1_dep-review_neo4j.md (PR 1.5.1)
NEO4J_IMAGE="neo4j:5.26-community@sha256:7a7e514888d668103d4a3a28516613ffdbb79f2161f91e49dfbd57c2b7f10d8f"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"
NEO4J_AUTH=neo4j/password

# Qdrant - Vector Database
# Multi-arch index digest resolved 2026-04-08 (PR FU-2).
QDRANT_IMAGE="qdrant/qdrant:v1.12.6@sha256:89d9d35757eb57c62973c193c96b5b50ca73bbaff7fa282ef81f7fd155a3747d"
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# MinIO - Object Storage
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET="legal-documents"
MINIO_SECURE=false

# ============================================
# AI/ML CONFIGURATION
# ============================================
# OpenAI API (Optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"
OPENAI_EMBEDDING_MODEL="text-embedding-ada-002"

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-3-opus-20240229"

# Local Model Settings
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
MODEL_PATH="./models"
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL="noreply@legalai.com"
EMAILS_FROM_NAME="Legal AI Platform"

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL="INFO"
SENTRY_DSN=""
PROMETHEUS_ENABLED=false
JAEGER_ENABLED=false
JAEGER_AGENT_HOST="localhost"
JAEGER_AGENT_PORT=6831

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# ============================================
# DOCKER / INFRASTRUCTURE
# ============================================
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
CLAMAV_NO_FRESHCLAM=false
CLAMAV_NO_CLAMD=false
BACKEND_HOST=0.0.0.0

# ============================================
# SERVICE PORTS
# ============================================
POSTGRES_PORT=5432
REDIS_PORT=6379
NEO4J_HTTP_PORT=7474
NEO4J_PORT=7687
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
CLAMAV_PORT=3310
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================
# FRONTEND (VITE)
# ============================================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME="Legal AI Platform"
VITE_APP_VERSION=1.0.0
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
DEBUG=true
TESTING=false
RELOAD=true

# ============================================
# DEPLOYMENT SETTINGS
# ============================================
HOST="0.0.0.0"
PORT=8000
WORKERS=4
WORKER_CLASS="uvicorn.workers.UvicornWorker"

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_GRAPHRAG=true
ENABLE_HRM=true
ENABLE_NEURAL_RAG=false
ENABLE_CONTRACT_ANALYTICS=true
ENABLE_AI_SUGGESTIONS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# MULTI-TENANCY
# ============================================
ENABLE_MULTI_TENANCY=true
# UUID per PR FU-1 (tenants.id migrated from Integer to UUID). Override
# this with your actual bootstrapped tenant UUID after the first run.
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"
MAX_TENANTS=100
TENANT_ISOLATION_MODE="database"  # Options: database, schema, row

# ============================================
# STORAGE LIMITS
# ============================================
MAX_FILE_SIZE_MB=50
MAX_STORAGE_PER_TENANT_GB=100
ALLOWED_FILE_EXTENSIONS=[".pdf",".docx",".doc",".txt",".xlsx",".xls"]

# ============================================
# PERFORMANCE TUNING
# ============================================
CACHE_TTL_SECONDS=3600
VECTOR_SEARCH_LIMIT=20
GRAPH_TRAVERSAL_DEPTH=3
BATCH_PROCESSING_SIZE=100

# ============================================
# COMPLIANCE & SECURITY
# ============================================
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_ENCRYPTION=true
GDPR_COMPLIANCE_MODE=false
SOC2_COMPLIANCE_MODE=false
DATA_RETENTION_DAYS=2555  # 7 years

# ============================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
SALESFORCE_REDIRECT_URI=""

DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_SECRET_KEY=""
DOCUSIGN_REDIRECT_URI=""

SLACK_BOT_TOKEN=""
SLACK_APP_TOKEN=""

MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""